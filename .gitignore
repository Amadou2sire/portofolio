# Python
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/venv/
backend/.venv/
backend/env/
backend/.env/
backend/instance/
backend/.pytest_cache/

# Environment variables
.env
frontend/.env
backend/.env

# Editor / OS
.vscode/
.idea/
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.antigravity/

# Artifacts
artifacts/
tmp/

# Migration & Automation scripts
backend/transform_to_supabase.py
backend/supabase_schema.sql
set_vercel_env.py
vercel_output.txt
test_file.txt
